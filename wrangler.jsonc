{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "codex-events-local",
	"compatibility_date": "2026-03-23",
	"compatibility_flags": [
		"nodejs_compat",
		"no_nodejs_compat_v2"
	],
	"ratelimits": [
		{
			"name": "PUBLIC_CONTACT_RATE_LIMITER",
			"namespace_id": "1001",
			"simple": {
				"limit": 5,
				"period": 60
			}
		},
		{
			"name": "AUTHENTICATED_UPLOAD_RATE_LIMITER",
			"namespace_id": "1002",
			"simple": {
				"limit": 10,
				"period": 60
			}
		},
		{
			"name": "PUBLIC_EVENT_FEEDBACK_RATE_LIMITER",
			"namespace_id": "1003",
			"simple": {
				"limit": 1,
				"period": 60
			}
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "codex-events-local",
			"database_id": "00000000-0000-0000-0000-000000000001",
			"migrations_dir": "drizzle"
		}
	],
	"r2_buckets": [
		{
			"binding": "PROFILE_ICONS",
			"bucket_name": "codex-events-local-profile-icons"
		},
		{
			"binding": "EVENT_IMAGES",
			"bucket_name": "codex-events-local-event-images"
		}
	],
	"images": {
		"binding": "IMAGES"
	},
	"send_email": [
		{
			"name": "EMAIL",
			"allowed_sender_addresses": [
				"info@codex-events.com"
			]
		}
	],
	"queues": {
		"producers": [
			{
				"binding": "APPLICATION_REVIEW_EMAIL_QUEUE",
				"queue": "codex-events-application-review-email-delivery"
			},
			{
				"binding": "EVENT_OUTCOME_EMAIL_QUEUE",
				"queue": "codex-events-event-outcome-email-delivery"
			},
			{
				"binding": "APPLICATION_LUMA_SYNC_QUEUE",
				"queue": "codex-events-application-luma-sync"
			}
		],
		"consumers": [
			{
				"queue": "codex-events-application-review-email-delivery",
				"max_batch_size": 10,
				"max_batch_timeout": 5,
				"max_retries": 10,
				"retry_delay": 120
			},
			{
				"queue": "codex-events-event-outcome-email-delivery",
				"max_batch_size": 10,
				"max_batch_timeout": 5,
				"max_retries": 10,
				"retry_delay": 120
			},
			{
				"queue": "codex-events-application-luma-sync",
				"max_batch_size": 10,
				"max_batch_timeout": 5,
				"max_retries": 10,
				"retry_delay": 120
			}
		]
	},
	"env": {
		"dev": {
			"name": "codex-events-dev",
			"main": ".output/server/index.mjs",
			"workers_dev": true,
			"preview_urls": false,
			"build": {
				"command": "bun run build:cloudflare"
			},
			"ratelimits": [
				{
					"name": "PUBLIC_CONTACT_RATE_LIMITER",
					"namespace_id": "2001",
					"simple": {
						"limit": 5,
						"period": 60
					}
				},
				{
					"name": "AUTHENTICATED_UPLOAD_RATE_LIMITER",
					"namespace_id": "2002",
					"simple": {
						"limit": 10,
						"period": 60
					}
				},
				{
					"name": "PUBLIC_EVENT_FEEDBACK_RATE_LIMITER",
					"namespace_id": "2003",
					"simple": {
						"limit": 1,
						"period": 60
					}
				}
			],
			"assets": {
				"binding": "ASSETS",
				"directory": ".output/public"
			},
			"routes": [
				{
					"pattern": "dev.codex-events.com",
					"custom_domain": true
				}
			],
				"vars": {
					"NUXT_AUTH0_DOMAIN": "auth.dev.codex-events.com",
					"NUXT_AUTH0_APP_BASE_URL": "https://dev.codex-events.com",
					"NUXT_EVENT_IMAGES_PUBLIC_CDN_BASE_URL": "https://cdn.dev.codex-events.com",
					"NUXT_AUTH0_MANAGEMENT_DOMAIN": "codex-events-dev.eu.auth0.com",
					"NUXT_AUTH0_MANAGEMENT_AUDIENCE": "https://codex-events-dev.eu.auth0.com/api/v2/",
					"NUXT_AUTH0_DATABASE_CONNECTION_NAME": "codex-events-e2e-users",
					"NUXT_OUTBOUND_EMAIL_BINDING": "EMAIL",
					"NUXT_OUTBOUND_EMAIL_FROM_EMAIL": "info@dev.codex-events.com",
					"NUXT_OUTBOUND_EMAIL_FROM_NAME": "Codex Events",
					"NUXT_OUTBOUND_EMAIL_REPLY_TO": "support@codex-events.com",
					"NUXT_APPLICATION_REVIEW_EMAILS_QUEUE_BINDING": "APPLICATION_REVIEW_EMAIL_QUEUE",
					"NUXT_APPLICATION_REVIEW_EMAILS_QUEUE_NAME": "dev-codex-events-application-review-email-delivery",
					"NUXT_APPLICATION_REVIEW_EMAILS_RETRY_DELAY_SECONDS": "120",
					"NUXT_EVENT_OUTCOME_EMAILS_QUEUE_BINDING": "EVENT_OUTCOME_EMAIL_QUEUE",
					"NUXT_EVENT_OUTCOME_EMAILS_QUEUE_NAME": "dev-codex-events-event-outcome-email-delivery",
					"NUXT_EVENT_OUTCOME_EMAILS_RETRY_DELAY_SECONDS": "120",
					"NUXT_LUMA_QUEUE_BINDING": "APPLICATION_LUMA_SYNC_QUEUE",
					"NUXT_LUMA_QUEUE_NAME": "dev-codex-events-application-luma-sync",
					"NUXT_LUMA_RETRY_DELAY_SECONDS": "120"
			},
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "dev-codex-events",
					"database_id": "53a5509d-097e-4fa5-bcc9-7a9c1cc0040e",
					"migrations_dir": "drizzle"
				}
			],
			"r2_buckets": [
				{
					"binding": "PROFILE_ICONS",
					"bucket_name": "dev-codex-events-profile-icons"
				},
				{
					"binding": "EVENT_IMAGES",
					"bucket_name": "dev-codex-events-event-images"
				}
			],
			"images": {
				"binding": "IMAGES"
			},
			"send_email": [
				{
					"name": "EMAIL",
					"allowed_sender_addresses": [
						"info@dev.codex-events.com"
					]
				}
			],
			"queues": {
				"producers": [
					{
						"binding": "APPLICATION_REVIEW_EMAIL_QUEUE",
						"queue": "dev-codex-events-application-review-email-delivery"
					},
					{
						"binding": "EVENT_OUTCOME_EMAIL_QUEUE",
						"queue": "dev-codex-events-event-outcome-email-delivery"
					},
					{
						"binding": "APPLICATION_LUMA_SYNC_QUEUE",
						"queue": "dev-codex-events-application-luma-sync"
					}
				],
				"consumers": [
					{
						"queue": "dev-codex-events-application-review-email-delivery",
						"max_batch_size": 10,
						"max_batch_timeout": 5,
						"max_retries": 10,
						"retry_delay": 120
					},
					{
						"queue": "dev-codex-events-event-outcome-email-delivery",
						"max_batch_size": 10,
						"max_batch_timeout": 5,
						"max_retries": 10,
						"retry_delay": 120
					},
					{
						"queue": "dev-codex-events-application-luma-sync",
						"max_batch_size": 10,
						"max_batch_timeout": 5,
						"max_retries": 10,
						"retry_delay": 120
					}
				]
			}
		},
		"production": {
			"name": "codex-events",
			"main": ".output/server/index.mjs",
			"workers_dev": false,
			"preview_urls": false,
			"build": {
				"command": "bun run build:cloudflare"
			},
			"ratelimits": [
				{
					"name": "PUBLIC_CONTACT_RATE_LIMITER",
					"namespace_id": "3001",
					"simple": {
						"limit": 5,
						"period": 60
					}
				},
				{
					"name": "AUTHENTICATED_UPLOAD_RATE_LIMITER",
					"namespace_id": "3002",
					"simple": {
						"limit": 10,
						"period": 60
					}
				},
				{
					"name": "PUBLIC_EVENT_FEEDBACK_RATE_LIMITER",
					"namespace_id": "3003",
					"simple": {
						"limit": 1,
						"period": 60
					}
				}
			],
			"assets": {
				"binding": "ASSETS",
				"directory": ".output/public"
			},
			"routes": [
				{
					"pattern": "codex-events.com",
					"custom_domain": true
				}
			],
				"vars": {
					"NUXT_AUTH0_DOMAIN": "auth.codex-events.com",
					"NUXT_AUTH0_APP_BASE_URL": "https://codex-events.com",
					"NUXT_EVENT_IMAGES_PUBLIC_CDN_BASE_URL": "https://cdn.codex-events.com",
					"NUXT_AUTH0_MANAGEMENT_DOMAIN": "codex-events.eu.auth0.com",
					"NUXT_AUTH0_MANAGEMENT_AUDIENCE": "https://codex-events.eu.auth0.com/api/v2/",
					"NUXT_AUTH0_DATABASE_CONNECTION_NAME": "Username-Password-Authentication",
					"NUXT_OUTBOUND_EMAIL_BINDING": "EMAIL",
					"NUXT_OUTBOUND_EMAIL_FROM_EMAIL": "info@codex-events.com",
					"NUXT_OUTBOUND_EMAIL_FROM_NAME": "Codex Events",
					"NUXT_OUTBOUND_EMAIL_REPLY_TO": "support@codex-events.com",
					"NUXT_APPLICATION_REVIEW_EMAILS_QUEUE_BINDING": "APPLICATION_REVIEW_EMAIL_QUEUE",
					"NUXT_APPLICATION_REVIEW_EMAILS_QUEUE_NAME": "codex-events-application-review-email-delivery",
					"NUXT_APPLICATION_REVIEW_EMAILS_RETRY_DELAY_SECONDS": "120",
					"NUXT_EVENT_OUTCOME_EMAILS_QUEUE_BINDING": "EVENT_OUTCOME_EMAIL_QUEUE",
					"NUXT_EVENT_OUTCOME_EMAILS_QUEUE_NAME": "codex-events-event-outcome-email-delivery",
					"NUXT_EVENT_OUTCOME_EMAILS_RETRY_DELAY_SECONDS": "120",
					"NUXT_LUMA_QUEUE_BINDING": "APPLICATION_LUMA_SYNC_QUEUE",
					"NUXT_LUMA_QUEUE_NAME": "codex-events-application-luma-sync",
					"NUXT_LUMA_RETRY_DELAY_SECONDS": "120"
			},
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "codex-events",
					"database_id": "4a138b1e-0267-47c4-8124-ab75cb530e28",
					"migrations_dir": "drizzle"
				}
			],
			"r2_buckets": [
				{
					"binding": "PROFILE_ICONS",
					"bucket_name": "codex-events-profile-icons"
				},
				{
					"binding": "EVENT_IMAGES",
					"bucket_name": "codex-events-event-images"
				}
			],
			"images": {
				"binding": "IMAGES"
			},
			"send_email": [
				{
					"name": "EMAIL",
					"allowed_sender_addresses": [
						"info@codex-events.com"
					]
				}
			],
			"queues": {
				"producers": [
					{
						"binding": "APPLICATION_REVIEW_EMAIL_QUEUE",
						"queue": "codex-events-application-review-email-delivery"
					},
					{
						"binding": "EVENT_OUTCOME_EMAIL_QUEUE",
						"queue": "codex-events-event-outcome-email-delivery"
					},
					{
						"binding": "APPLICATION_LUMA_SYNC_QUEUE",
						"queue": "codex-events-application-luma-sync"
					}
				],
				"consumers": [
					{
						"queue": "codex-events-application-review-email-delivery",
						"max_batch_size": 10,
						"max_batch_timeout": 5,
						"max_retries": 10,
						"retry_delay": 120
					},
					{
						"queue": "codex-events-event-outcome-email-delivery",
						"max_batch_size": 10,
						"max_batch_timeout": 5,
						"max_retries": 10,
						"retry_delay": 120
					},
					{
						"queue": "codex-events-application-luma-sync",
						"max_batch_size": 10,
						"max_batch_timeout": 5,
						"max_retries": 10,
						"retry_delay": 120
					}
				]
			}
		}
	}
}
