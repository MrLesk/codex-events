{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "codex-hackathons-local",
  "compatibility_date": "2026-03-23",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "codex-hackathons-local",
      "database_id": "00000000-0000-0000-0000-000000000001",
      "migrations_dir": "drizzle"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PROFILE_ICONS",
      "bucket_name": "codex-hackathons-local-profile-icons"
    },
    {
      "binding": "HACKATHON_IMAGES",
      "bucket_name": "codex-hackathons-local-hackathon-images"
    }
  ]
}
