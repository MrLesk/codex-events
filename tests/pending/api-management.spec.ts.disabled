import { expect, test } from '@playwright/test'

import { createAuthenticatedApiClient } from '../bdd/support/api-client'

test.describe.serial('TASK-3.5 API management flows', () => {
  test('platform admin can read session context and perform guarded hackathon management writes', async () => {
    const apiClient = await createAuthenticatedApiClient('platform_admin')

    try {
      const sessionResponse = await apiClient.get('/api/session')
      expect(sessionResponse.ok()).toBe(true)
      await expect(sessionResponse.json()).resolves.toMatchObject({
        data: {
          actor: {
            kind: 'platform_user',
            isPlatformAdmin: true
          }
        }
      })

      const now = Date.now()
      const createResponse = await apiClient.post('/api/hackathons', {
        data: {
          name: 'E2E Managed Hackathon',
          slug: `e2e-managed-hackathon-${now}`,
          description: 'Hackathon created by Auth0-backed E2E coverage.',
          city: 'Vienna',
          address: 'Fixture Address',
          registrationOpensAt: new Date(now - 3_600_000).toISOString(),
          registrationClosesAt: new Date(now + 86_400_000).toISOString(),
          submissionOpensAt: new Date(now + 86_400_000).toISOString(),
          submissionClosesAt: new Date(now + 172_800_000).toISOString(),
          maxTeamMembers: 5,
          requireXProfile: false,
          requireLinkedinProfile: false,
          requireGithubProfile: false
        }
      })
      expect(createResponse.ok()).toBe(true)

      const createdHackathonPayload = await createResponse.json()
      expect(createdHackathonPayload).toMatchObject({
        data: {
          state: 'draft'
        }
      })
      const createdHackathonId = createdHackathonPayload.data.id

      const criterionResponse = await apiClient.post(`/api/hackathons/${createdHackathonId}/evaluation-criteria`, {
        data: {
          name: 'Execution',
          description: 'Measures execution quality.',
          weight: 30,
          displayOrder: 1
        }
      })
      expect(criterionResponse.ok()).toBe(true)
      await expect(criterionResponse.json()).resolves.toMatchObject({
        data: {
          name: 'Execution',
          displayOrder: 1
        }
      })

      const guardedOpenSubmissionResponse = await apiClient.post(`/api/hackathons/${createdHackathonId}/actions/open-submission`)
      expect(guardedOpenSubmissionResponse.status()).toBe(409)
      await expect(guardedOpenSubmissionResponse.json()).resolves.toMatchObject({
        error: {
          code: 'hackathon_state_invalid'
        }
      })
    } finally {
      await apiClient.dispose()
    }
  })

  test('regular users can accept the current platform document version through the authenticated session', async () => {
    const apiClient = await createAuthenticatedApiClient('regular_user')

    try {
      const currentDocumentsResponse = await apiClient.get('/api/platform-documents/current')
      expect(currentDocumentsResponse.ok()).toBe(true)
      const currentDocumentsPayload = await currentDocumentsResponse.json()
      const privacyPolicyId = currentDocumentsPayload.data.privacy_policy?.id

      expect(privacyPolicyId).toBeTruthy()

      const acceptanceResponse = await apiClient.post('/api/platform-document-acceptances', {
        data: {
          platformDocumentId: privacyPolicyId
        }
      })
      expect(acceptanceResponse.ok()).toBe(true)
      await expect(acceptanceResponse.json()).resolves.toMatchObject({
        data: {
          acceptance: {
            platformDocumentId: privacyPolicyId
          },
          document: {
            id: privacyPolicyId
          }
        }
      })
    } finally {
      await apiClient.dispose()
    }
  })

  test('regular users can delete their own account and fall back to authenticated-identity session state', async () => {
    const apiClient = await createAuthenticatedApiClient('regular_user')

    try {
      const deleteResponse = await apiClient.delete('/api/account')
      expect(deleteResponse.ok()).toBe(true)
      await expect(deleteResponse.json()).resolves.toMatchObject({
        data: {
          userId: 'user_regular_user'
        }
      })

      const sessionResponse = await apiClient.get('/api/session')
      expect(sessionResponse.ok()).toBe(true)
      await expect(sessionResponse.json()).resolves.toMatchObject({
        data: {
          actor: {
            kind: 'authenticated_identity',
            hasPlatformAccount: false
          }
        }
      })
    } finally {
      await apiClient.dispose()
    }
  })
})
