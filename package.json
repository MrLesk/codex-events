{
  "name": "codex-hackathons",
  "private": true,
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "node ./node_modules/nuxt/bin/nuxt.mjs dev",
    "db:generate": "drizzle-kit generate",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "test:bdd:install": "playwright install chromium",
    "test:unit": "node ./node_modules/vitest/vitest.mjs run tests/unit",
    "test:integration": "node ./node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts",
    "test:bdd": "bun tests/bdd/bootstrap.ts && bddgen && playwright test --project chromium-bdd --project chromium-authenticated-bdd && bun tests/bdd/bootstrap.ts && playwright test --project chromium-authenticated-destructive-bdd --workers=1",
    "test:all": "bun run test:unit && bun run test:integration && bun run test:bdd"
  },
  "dependencies": {
    "@auth0/auth0-nuxt": "1.0.1",
    "@iconify-json/lucide": "1.2.98",
    "@iconify-json/simple-icons": "1.2.74",
    "@nuxt/ui": "4.5.1",
    "drizzle-orm": "0.45.1",
    "nuxt": "4.4.2",
    "tailwindcss": "4.2.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "1.15.2",
    "@playwright/test": "1.58.2",
    "@types/node": "25.5.0",
    "dotenv": "17.3.1",
    "drizzle-kit": "0.31.10",
    "eslint": "10.1.0",
    "miniflare": "4.20260317.1",
    "playwright-bdd": "8.5.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "vue-tsc": "3.2.6",
    "wrangler": "4.76.0"
  }
}
