{
  "name": "codex-hackathons",
  "private": true,
  "version": "1.2.3",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "auth0:custom-domain": "bun tools/auth0/auth0-custom-domain.ts",
    "build": "nuxt build",
    "build:cloudflare": "NITRO_PRESET=cloudflare_module nuxt build",
    "db:local:guard": "bun tools/d1/ensure-local-state-path.ts",
    "db:migrate:dev": "CLOUDFLARE_API_TOKEN=${CLOUDFLARE_MGMT_TOKEN:-$CLOUDFLARE_API_TOKEN} wrangler d1 migrations apply DB --remote --env dev --config wrangler.jsonc",
    "db:migrate:production": "CLOUDFLARE_API_TOKEN=${CLOUDFLARE_MGMT_TOKEN:-$CLOUDFLARE_API_TOKEN} wrangler d1 migrations apply DB --remote --env production --config wrangler.jsonc",
    "dev": "LOCAL_D1_STATE_ROOT=${LOCAL_D1_STATE_ROOT:-${LOCAL_DEV_D1_STATE_ROOT:-.wrangler/state}} bun run dev:inner",
    "dev:inner": "bun run db:local:guard && CI=1 wrangler d1 migrations apply DB --local --persist-to ${LOCAL_D1_STATE_ROOT} --config wrangler.jsonc && nuxt dev",
    "deploy:dev": "CLOUDFLARE_API_TOKEN=${CLOUDFLARE_MGMT_TOKEN:-$CLOUDFLARE_API_TOKEN} wrangler deploy --env dev --config wrangler.jsonc",
    "deploy:production": "CLOUDFLARE_API_TOKEN=${CLOUDFLARE_MGMT_TOKEN:-$CLOUDFLARE_API_TOKEN} wrangler deploy --env production --config wrangler.jsonc",
    "db:generate": "drizzle-kit generate",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "notices:generate": "bun tools/licenses/generate-third-party-notices.ts",
    "typecheck": "nuxt typecheck",
    "release:version": "bun tools/releases/release-version.ts",
    "test:bdd:install": "playwright install chromium",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:bdd": "LOCAL_BDD_D1_STATE_ROOT=${LOCAL_BDD_D1_STATE_ROOT:-.wrangler/state-bdd} LOCAL_D1_STATE_ROOT=${LOCAL_BDD_D1_STATE_ROOT:-.wrangler/state-bdd} bun run test:bdd:inner",
    "test:bdd:inner": "bun run db:local:guard && bun tests/bdd/bootstrap.ts && bddgen && playwright test --project chromium-bdd --project chromium-authenticated-bdd && bun tests/bdd/bootstrap.ts && playwright test --project chromium-authenticated-destructive-bdd --workers=1",
    "test:all": "bun run test:unit && bun run test:integration && bun run test:bdd"
  },
  "dependencies": {
    "@auth0/auth0-nuxt": "1.1.0",
    "@iconify-json/lucide": "1.2.103",
    "@iconify-json/simple-icons": "1.2.79",
    "@nuxt/icon": "^2.2.1",
    "@tailwindcss/vite": "^4.2.4",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "fuse.js": "^7.3.0",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.1.1",
    "md-editor-v3": "^6.4.2",
    "nuxt": "4.4.2",
    "photoswipe": "^5.4.4",
    "reka-ui": "^2.9.6",
    "shadcn-nuxt": "2.6.2",
    "sortablejs": "^1.15.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "4.2.4",
    "vee-validate": "^4.15.1",
    "vue-sonner": "^2.0.9",
    "zod": "4.3.6"
  },
  "overrides": {
    "h3": "1.15.10"
  },
  "devDependencies": {
    "@nuxt/eslint": "1.15.2",
    "@playwright/test": "1.59.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "25.6.0",
    "@types/sortablejs": "^1.15.9",
    "@types/sql.js": "^1.4.11",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "10.2.1",
    "miniflare": "4.20260424.0",
    "playwright-bdd": "8.5.0",
    "sql.js": "^1.14.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "vue-tsc": "3.2.7",
    "wrangler": "^4.85.0"
  }
}
