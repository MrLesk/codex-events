{
  "name": "codex-hackathons",
  "private": true,
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:cloudflare": "NITRO_PRESET=cloudflare_module nuxt build",
    "db:local:guard": "bun tools/d1/ensure-local-state-path.ts",
    "db:migrate:dev": "CLOUDFLARE_API_TOKEN=${CLOUDFLARE_MGMT_TOKEN:-$CLOUDFLARE_API_TOKEN} wrangler d1 migrations apply DB --remote --env dev --config wrangler.jsonc",
    "dev": "bun run db:local:guard && CI=1 wrangler d1 migrations apply DB --local --persist-to ${LOCAL_D1_STATE_ROOT:-.wrangler/state} --config wrangler.jsonc && nuxt dev",
    "deploy:dev": "CLOUDFLARE_API_TOKEN=${CLOUDFLARE_MGMT_TOKEN:-$CLOUDFLARE_API_TOKEN} wrangler deploy --env dev --config wrangler.jsonc",
    "db:generate": "drizzle-kit generate",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "test:bdd:install": "playwright install chromium",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:bdd": "bun run db:local:guard && bun tests/bdd/bootstrap.ts && bddgen && playwright test --project chromium-bdd --project chromium-authenticated-bdd && bun tests/bdd/bootstrap.ts && playwright test --project chromium-authenticated-destructive-bdd --workers=1",
    "test:all": "bun run test:unit && bun run test:integration && bun run test:bdd"
  },
  "dependencies": {
    "@auth0/auth0-nuxt": "1.0.1",
    "@iconify-json/lucide": "1.2.98",
    "@iconify-json/simple-icons": "1.2.74",
    "@nuxt/icon": "^2.2.1",
    "@react-email/render": "2.0.4",
    "@tailwindcss/vite": "^4.2.2",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.1",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.1.1",
    "md-editor-v3": "^6.4.1",
    "nuxt": "4.4.2",
    "reka-ui": "^2.9.2",
    "resend": "6.9.4",
    "shadcn-nuxt": "2.4.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "4.2.2",
    "vee-validate": "^4.15.1",
    "vue-sonner": "^2.0.9",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "1.15.2",
    "@playwright/test": "1.58.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "25.5.0",
    "dotenv": "17.3.1",
    "drizzle-kit": "0.31.10",
    "eslint": "10.1.0",
    "miniflare": "4.20260317.1",
    "playwright-bdd": "8.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "vue-tsc": "3.2.6",
    "wrangler": "4.76.0"
  }
}
