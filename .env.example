# Auth0 runtime.
NUXT_AUTH0_DOMAIN=your-tenant.auth0.com
NUXT_AUTH0_CLIENT_ID=your-auth0-client-id
NUXT_AUTH0_CLIENT_SECRET=your-auth0-client-secret
NUXT_AUTH0_SESSION_SECRET=replace-with-generated-session-secret
NUXT_AUTH0_APP_BASE_URL=http://localhost:3000
# Optional dedicated local origin for the Auth0-backed BDD suite.
# If omitted, the BDD harness defaults to http://localhost:3100.
# NUXT_AUTH0_BDD_APP_BASE_URL=http://localhost:3100
NUXT_AUTH0_AUDIENCE=
NUXT_AUTH0_DATABASE_CONNECTION_NAME=Username-Password-Authentication
NUXT_AUTH0_ACCOUNT_LINK_CHALLENGE_SECRET=replace-with-generated-account-link-secret
NUXT_FIRST_PLATFORM_ADMIN_EMAIL=

# Cloudflare (CF) runtime bindings.
NUXT_DATABASE_BINDING=DB
NUXT_PROFILE_ICONS_BINDING=PROFILE_ICONS
NUXT_EVENT_IMAGES_BINDING=EVENT_IMAGES

# Cloudflare (CF) Email Service runtime settings.
NUXT_OUTBOUND_EMAIL_BINDING=EMAIL
NUXT_OUTBOUND_EMAIL_FROM_EMAIL=
NUXT_OUTBOUND_EMAIL_FROM_NAME=Codex Events
NUXT_OUTBOUND_EMAIL_REPLY_TO=

# Cloudflare (CF) Queues runtime settings.
NUXT_APPLICATION_REVIEW_EMAILS_QUEUE_BINDING=APPLICATION_REVIEW_EMAIL_QUEUE
NUXT_APPLICATION_REVIEW_EMAILS_QUEUE_NAME=codex-events-test-application-review-email-delivery
NUXT_APPLICATION_REVIEW_EMAILS_RETRY_DELAY_SECONDS=120
NUXT_EVENT_OUTCOME_EMAILS_QUEUE_BINDING=EVENT_OUTCOME_EMAIL_QUEUE
NUXT_EVENT_OUTCOME_EMAILS_QUEUE_NAME=codex-events-test-event-outcome-email-delivery
NUXT_EVENT_OUTCOME_EMAILS_RETRY_DELAY_SECONDS=120

# Luma runtime settings.
NUXT_LUMA_API_KEY=
NUXT_LUMA_API_BASE_URL=https://public-api.luma.com
NUXT_LUMA_PROFILE_BASE_URL=https://luma.com
NUXT_LUMA_QUEUE_BINDING=APPLICATION_LUMA_SYNC_QUEUE
NUXT_LUMA_QUEUE_NAME=codex-events-test-application-luma-sync
NUXT_LUMA_RETRY_DELAY_SECONDS=120
# Deployed environments upload this automatically after Luma webhook reconciliation.
# Set it explicitly only when you need to test Luma webhook verification locally.
NUXT_LUMA_WEBHOOK_SECRET=

# Optional local D1 persistence roots.
# Local app development defaults to `.wrangler/state`.
# Auth0-backed BDD defaults to `.wrangler/state-bdd`.
# BDD only honors `LOCAL_BDD_D1_STATE_ROOT` and fails fast if it resolves to the normal local app root.
LOCAL_DEV_D1_STATE_ROOT=.wrangler/state
LOCAL_BDD_D1_STATE_ROOT=.wrangler/state-bdd
# LOCAL_D1_STATE_ROOT=.wrangler/state-custom

# Auth0 tenant-automation variables used by:
# `bun tools/auth0/auth0-bootstrap.ts apply` and `bun tools/auth0/auth0-bootstrap.ts check`
AUTH0_MANAGEMENT_DOMAIN=your-tenant.auth0.com
AUTH0_MGMT_CLIENT_ID=your-management-client-id
AUTH0_MGMT_CLIENT_SECRET=your-management-client-secret
# Auth0 bootstrap uses NUXT_AUTH0_CLIENT_ID and NUXT_AUTH0_CLIENT_SECRET from the runtime section above.
AUTH0_APP_DISPLAY_NAME=Codex Events
AUTH0_APP_BASE_URL=https://your-platform.example
AUTH0_LOGIN_URI=https://your-platform.example/auth/login
# AUTH0_CUSTOM_DOMAIN defaults to auth.<AUTH0_APP_BASE_URL host>.
AUTH0_CUSTOM_DOMAIN=
# AUTH0_DATABASE_CONNECTION_NAME defaults to Username-Password-Authentication.
AUTH0_DATABASE_CONNECTION_NAME=
# Optional override. Defaults to the same generated value as NUXT_AUTH0_ACCOUNT_LINK_CHALLENGE_SECRET.
AUTH0_ACCOUNT_LINK_CHALLENGE_SECRET=
AUTH0_TERMS_URL=https://your-platform.example/terms-and-conditions
AUTH0_PRIVACY_URL=https://your-platform.example/privacy-policy
AUTH0_BRANDING_PRIMARY_COLOR=#030213
AUTH0_BRANDING_PAGE_BACKGROUND_COLOR=#f3f3f5
AUTH0_BRANDING_LOGO_URL=https://your-platform.example/auth0/codex-events-wordmark.svg
AUTH0_BRANDING_FAVICON_URL=https://your-platform.example/favicon.ico

# Optional explicit Luma webhook bootstrap variables used by:
# `bun tools/luma/webhook-bootstrap.ts apply` and `bun tools/luma/webhook-bootstrap.ts check`
# If omitted, the script falls back to NUXT_LUMA_API_KEY / NUXT_LUMA_API_BASE_URL and derives
# the webhook URL from an https NUXT_AUTH0_APP_BASE_URL when possible.
LUMA_API_KEY=
LUMA_API_BASE_URL=https://public-api.luma.com
LUMA_WEBHOOK_URL=https://your-platform.example/api/public/luma/webhooks

# Remote deployment defaults.
# Each GitHub environment stores only its own base domain.
# DEPLOY_ENV_NAME defaults to prod for production deploys and test for test deploys.
# AUTH0_CUSTOM_DOMAIN above is optional and defaults to auth.<BASE_DOMAIN>.
DEPLOY_ENV_NAME=prod
DEPLOY_RESOURCE_PREFIX=codex-events
BASE_DOMAIN=your-platform.example

# Remote deployment Cloudflare (CF) metadata.
# DEPLOY_CF_ZONE_NAME cannot be derived safely.
# The deploy workflow creates or finds the D1 database by name and resolves its ID automatically.
# Other DEPLOY_CF_* values below are optional overrides for generated resource names.
DEPLOY_CF_ZONE_NAME=your-platform.example
# DEPLOY_CF_WORKER_NAME=codex-events-prod
# DEPLOY_CF_D1_DATABASE_NAME=codex-events-prod
# DEPLOY_CF_PROFILE_ICONS_BUCKET=codex-events-prod-profile-icons
# DEPLOY_CF_EVENT_IMAGES_BUCKET=codex-events-prod-event-images
# DEPLOY_CF_APPLICATION_REVIEW_EMAIL_QUEUE=codex-events-prod-application-review-email-delivery
# DEPLOY_CF_EVENT_OUTCOME_EMAIL_QUEUE=codex-events-prod-event-outcome-email-delivery
# DEPLOY_CF_LUMA_SYNC_QUEUE=codex-events-prod-application-luma-sync

# Remote deployment public URL override.
DEPLOY_LUMA_WEBHOOK_URL=

# Cloudflare (CF) CLI/API credentials.
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# Used by drizzle-kit direct D1 access; it can match the target D1 database created by the deploy workflow.
CLOUDFLARE_D1_DATABASE_ID=your-d1-database-id

# Stable Auth0 personas for real Auth0-backed BDD login flows.
# BDD fixture provisioning uses AUTH0_MANAGEMENT_DOMAIN, AUTH0_MGMT_*, and
# NUXT_AUTH0_DATABASE_CONNECTION_NAME from the Auth0 sections above.
# Platform roles still come from the app database, not Auth0.
E2E_PLATFORM_ADMIN_EMAIL=platform-admin@example.com
E2E_PLATFORM_ADMIN_PASSWORD=replace-with-strong-password
E2E_EVENT_ADMIN_EMAIL=event-admin@example.com
E2E_EVENT_ADMIN_PASSWORD=replace-with-strong-password
E2E_JUDGE_EMAIL=judge@example.com
E2E_JUDGE_PASSWORD=replace-with-strong-password
E2E_REGULAR_USER_EMAIL=regular-user@example.com
E2E_REGULAR_USER_PASSWORD=replace-with-strong-password
