NUXT_AUTH0_DOMAIN=your-tenant.auth0.com
NUXT_AUTH0_CLIENT_ID=your-auth0-client-id
NUXT_AUTH0_CLIENT_SECRET=your-auth0-client-secret
NUXT_AUTH0_SESSION_SECRET=replace-with-openssl-rand-hex-64
NUXT_AUTH0_APP_BASE_URL=http://localhost:3000
NUXT_AUTH0_AUDIENCE=
NUXT_DATABASE_BINDING=DB
NUXT_PROFILE_ICONS_BINDING=PROFILE_ICONS
NUXT_HACKATHON_IMAGES_BINDING=HACKATHON_IMAGES
NUXT_RESEND_API_KEY=
NUXT_RESEND_FROM_EMAIL=
NUXT_RESEND_FROM_NAME=
NUXT_RESEND_REPLY_TO=
NUXT_APPLICATION_REVIEW_EMAILS_QUEUE_BINDING=APPLICATION_REVIEW_EMAIL_QUEUE
NUXT_APPLICATION_REVIEW_EMAILS_QUEUE_NAME=codex-hackathons-application-review-email-delivery
NUXT_APPLICATION_REVIEW_EMAILS_RETRY_DELAY_SECONDS=120

# Optional explicit Auth0 tenant-automation variables used by:
# `bun tools/auth0/auth0-bootstrap.ts apply` and `bun tools/auth0/auth0-bootstrap.ts check`
# If omitted, the script falls back to NUXT_AUTH0_* and AUTH0_TEST_MGMT_*.
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_MGMT_CLIENT_ID=your-management-client-id
AUTH0_MGMT_CLIENT_SECRET=your-management-client-secret
AUTH0_MGMT_AUDIENCE=https://your-tenant.auth0.com/api/v2/
AUTH0_APP_CLIENT_ID=your-auth0-client-id
AUTH0_CUSTOM_DOMAIN=auth.your-platform.example
AUTH0_APP_BASE_URL=https://your-platform.example
AUTH0_LOGIN_URI=https://your-platform.example/auth/login
AUTH0_TERMS_URL=https://your-platform.example/terms-and-conditions
AUTH0_PRIVACY_URL=https://your-platform.example/privacy-policy
AUTH0_BRANDING_PRIMARY_COLOR=#1f2937
AUTH0_BRANDING_PAGE_BACKGROUND_COLOR=#f8fafc
AUTH0_BRANDING_LOGO_URL=https://your-platform.example/logo.png
AUTH0_BRANDING_FAVICON_URL=https://your-platform.example/favicon.ico

CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_D1_DATABASE_ID=your-d1-database-id
CLOUDFLARE_R2_BUCKET=your-r2-bucket-name

# Auth0 Management API credentials for the test tenant.
# Used to create/reset Auth0-side BDD fixtures locally and in CI.
AUTH0_TEST_DOMAIN=your-tenant.auth0.com
AUTH0_TEST_MGMT_CLIENT_ID=your-test-management-client-id
AUTH0_TEST_MGMT_CLIENT_SECRET=your-test-management-client-secret
AUTH0_TEST_MGMT_AUDIENCE=https://your-tenant.auth0.com/api/v2/
AUTH0_TEST_CONNECTION_NAME=codex-hackathons-e2e-users

# Stable Auth0 personas for real Auth0-backed BDD login flows.
# Platform roles still come from the app database, not Auth0.
E2E_PLATFORM_ADMIN_EMAIL=platform-admin@example.com
E2E_PLATFORM_ADMIN_PASSWORD=replace-with-strong-password
E2E_HACKATHON_ADMIN_EMAIL=hackathon-admin@example.com
E2E_HACKATHON_ADMIN_PASSWORD=replace-with-strong-password
E2E_JUDGE_EMAIL=judge@example.com
E2E_JUDGE_PASSWORD=replace-with-strong-password
E2E_REGULAR_USER_EMAIL=regular-user@example.com
E2E_REGULAR_USER_PASSWORD=replace-with-strong-password
