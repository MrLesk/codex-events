# =============================================================================
# Copy to .env and fill in the values.
#
# Variables are grouped by the job they support. You do NOT need every group:
#   1) Local development          — to run `bun run dev`
#   2) Auth0 tenant automation    — for `bun tools/auth0/auth0-bootstrap.ts`
#   3) Manual remote deploy       — for `bun run deploy:*` outside GitHub Actions
#   4) BDD tests                  — for `bun run test:bdd`
#
# Deployed environments normally get these from their GitHub environment, not
# from this file. See OPERATOR.md (operators) and DEVELOPMENT.md (contributors).
# =============================================================================


# -----------------------------------------------------------------------------
# 1) LOCAL DEVELOPMENT  (needed to run `bun run dev`)
# -----------------------------------------------------------------------------

# --- Auth0 login (required) ---
# Auth0 issuer host — your tenant domain (or custom domain).
NUXT_AUTH0_DOMAIN=your-tenant.auth0.com
# Regular Web Application client ID and secret.
NUXT_AUTH0_CLIENT_ID=your-auth0-client-id
NUXT_AUTH0_CLIENT_SECRET=your-auth0-client-secret
# Machine-to-Machine application authorized for Auth0 Management API update:users.
NUXT_AUTH0_MANAGEMENT_CLIENT_ID=your-management-client-id
NUXT_AUTH0_MANAGEMENT_CLIENT_SECRET=your-management-client-secret
# Session cookie secret — generate one (e.g. `openssl rand -hex 64`).
NUXT_AUTH0_SESSION_SECRET=replace-with-generated-session-secret
# Account-linking challenge secret — generate one (e.g. `openssl rand -hex 32`).
NUXT_AUTH0_ACCOUNT_LINK_CHALLENGE_SECRET=replace-with-generated-account-link-secret
# Where the app runs locally.
NUXT_AUTH0_APP_BASE_URL=http://localhost:3000

# --- Auth0 login (optional) ---
# Database connection used for username/password sign-in (this is the default).
NUXT_AUTH0_DATABASE_CONNECTION_NAME=Username-Password-Authentication
# Promote this email to platform admin when no active admin exists.
NUXT_FIRST_PLATFORM_ADMIN_EMAIL=
# Dedicated origin for the Auth0-backed BDD suite (defaults to http://localhost:3100).
# NUXT_AUTH0_BDD_APP_BASE_URL=http://localhost:3100

# --- Cloudflare runtime bindings (optional; defaults match wrangler.jsonc) ---
NUXT_DATABASE_BINDING=DB
NUXT_PROFILE_ICONS_BINDING=PROFILE_ICONS
NUXT_EVENT_IMAGES_BINDING=EVENT_IMAGES

# --- Outbound email ---
# From-address — any address on your onboarded sending domain. Required to send email.
NUXT_OUTBOUND_EMAIL_FROM_EMAIL=
# Optional: Worker email binding name (default), sender display name, and reply-to
# (reply-to defaults to the from-address when empty).
NUXT_OUTBOUND_EMAIL_BINDING=EMAIL
NUXT_OUTBOUND_EMAIL_FROM_NAME=Codex Events
NUXT_OUTBOUND_EMAIL_REPLY_TO=

# --- Email queues (optional; bindings/names default to wrangler.jsonc, delays to 120s) ---
NUXT_APPLICATION_REVIEW_EMAILS_QUEUE_BINDING=APPLICATION_REVIEW_EMAIL_QUEUE
NUXT_APPLICATION_REVIEW_EMAILS_QUEUE_NAME=codex-events-dev-application-review-email-delivery
NUXT_APPLICATION_REVIEW_EMAILS_RETRY_DELAY_SECONDS=120
NUXT_EVENT_OUTCOME_EMAILS_QUEUE_BINDING=EVENT_OUTCOME_EMAIL_QUEUE
NUXT_EVENT_OUTCOME_EMAILS_QUEUE_NAME=codex-events-dev-event-outcome-email-delivery
NUXT_EVENT_OUTCOME_EMAILS_RETRY_DELAY_SECONDS=120

# --- Luma integration (optional; only when events use Luma sync) ---
# Event API keys are stored on each event in the admin settings.
NUXT_LUMA_API_BASE_URL=https://public-api.luma.com
NUXT_LUMA_PROFILE_BASE_URL=https://luma.com
NUXT_LUMA_QUEUE_BINDING=APPLICATION_LUMA_SYNC_QUEUE
NUXT_LUMA_QUEUE_NAME=codex-events-dev-application-luma-sync
NUXT_LUMA_RETRY_DELAY_SECONDS=120

# --- Local D1 persistence roots (optional; defaults shown) ---
# BDD only honors LOCAL_BDD_D1_STATE_ROOT and fails fast if it equals the app root.
LOCAL_DEV_D1_STATE_ROOT=.wrangler/state
LOCAL_BDD_D1_STATE_ROOT=.wrangler/state-bdd
# LOCAL_D1_STATE_ROOT=.wrangler/state-custom


# -----------------------------------------------------------------------------
# 2) AUTH0 TENANT AUTOMATION  (only for `bun tools/auth0/auth0-bootstrap.ts`)
# -----------------------------------------------------------------------------
# Also reuses NUXT_AUTH0_CLIENT_ID / NUXT_AUTH0_CLIENT_SECRET from section 1.

# --- Required ---
# Tenant hostname for the Management API.
AUTH0_MANAGEMENT_DOMAIN=your-tenant.auth0.com
# Machine-to-Machine application authorized for the Management API.
AUTH0_MGMT_CLIENT_ID=your-management-client-id
AUTH0_MGMT_CLIENT_SECRET=your-management-client-secret
# Deployed app base URL the tenant is configured against.
AUTH0_APP_BASE_URL=https://your-platform.example

# --- Required only when AUTH0_APP_BASE_URL is not HTTPS (must itself be HTTPS) ---
AUTH0_LOGIN_URI=https://your-platform.example/auth/login

# --- Optional (have defaults) ---
# Name shown in Auth0-hosted login copy.
AUTH0_APP_DISPLAY_NAME=Codex Events
# Login hostname; defaults to auth.<AUTH0_APP_BASE_URL host>.
AUTH0_CUSTOM_DOMAIN=
# Defaults to Username-Password-Authentication.
AUTH0_DATABASE_CONNECTION_NAME=
# Defaults to the same generated value as NUXT_AUTH0_ACCOUNT_LINK_CHALLENGE_SECRET.
AUTH0_ACCOUNT_LINK_CHALLENGE_SECRET=

# --- Optional Universal Login legal links + branding (have defaults) ---
AUTH0_TERMS_URL=https://your-platform.example/terms-and-conditions
AUTH0_PRIVACY_URL=https://your-platform.example/privacy-policy
AUTH0_BRANDING_PRIMARY_COLOR=#030213
AUTH0_BRANDING_PAGE_BACKGROUND_COLOR=#f3f3f5
AUTH0_BRANDING_LOGO_URL=https://your-platform.example/auth0/codex-events-wordmark.svg
AUTH0_BRANDING_FAVICON_URL=https://your-platform.example/favicon.ico


# -----------------------------------------------------------------------------
# 3) MANUAL REMOTE DEPLOY  (only for `bun run deploy:*` outside GitHub Actions)
# -----------------------------------------------------------------------------

# --- Required ---
# App hostname for this environment.
BASE_DOMAIN=your-platform.example
# Cloudflare DNS zone (cannot be derived) — usually the parent domain of BASE_DOMAIN.
CF_ZONE_NAME=your-platform.example
# Cloudflare account ID and an API token with the scopes listed in OPERATOR.md.
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token

# --- Optional ---
# Resource-name suffix; defaults to prod for the production target, test for the test target.
ENV_NAME=prod
# Resource-name prefix.
RESOURCE_PREFIX=codex-events
# Separate token used for D1 migrations; falls back to CF_API_TOKEN when empty.
CF_MGMT_TOKEN=
# For drizzle-kit direct D1 access; the deploy resolves the database ID automatically otherwise.
CF_D1_DATABASE_ID=your-d1-database-id

# --- Optional Cloudflare resource-name overrides (deploy generates these by default) ---
# CF_WORKER_NAME=codex-events-prod
# CF_D1_DATABASE_NAME=codex-events-prod
# CF_PROFILE_ICONS_BUCKET=codex-events-prod-profile-icons
# CF_EVENT_IMAGES_BUCKET=codex-events-prod-event-images
# CF_APPLICATION_REVIEW_EMAIL_QUEUE=codex-events-prod-application-review-email-delivery
# CF_EVENT_OUTCOME_EMAIL_QUEUE=codex-events-prod-event-outcome-email-delivery
# CF_LUMA_SYNC_QUEUE=codex-events-prod-application-luma-sync


# -----------------------------------------------------------------------------
# 4) BDD TESTS  (only for the Auth0-backed `bun run test:bdd`)
# -----------------------------------------------------------------------------
# Stable Auth0 personas for real login flows. Provisioning reuses
# AUTH0_MANAGEMENT_DOMAIN, AUTH0_MGMT_*, and NUXT_AUTH0_DATABASE_CONNECTION_NAME.
# Platform roles come from the app database, not Auth0.
E2E_PLATFORM_ADMIN_EMAIL=platform-admin@example.com
E2E_PLATFORM_ADMIN_PASSWORD=replace-with-strong-password
E2E_EVENT_ADMIN_EMAIL=event-admin@example.com
E2E_EVENT_ADMIN_PASSWORD=replace-with-strong-password
E2E_JUDGE_EMAIL=judge@example.com
E2E_JUDGE_PASSWORD=replace-with-strong-password
E2E_REGULAR_USER_EMAIL=regular-user@example.com
E2E_REGULAR_USER_PASSWORD=replace-with-strong-password
